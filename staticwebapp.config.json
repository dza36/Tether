{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/icon-*", "/manifest*.json", "/about.json", "/app.css", "/app.js", "/supabase.js", "/config.js", "/version.js", "/grocery-data.js"]
  },
  "globalHeaders": {
    "Cache-Control": "no-cache, no-store, must-revalidate",
    "Pragma": "no-cache",
    "Expires": "0",
    "X-Content-Type-Options": "nosniff"
  }
}
